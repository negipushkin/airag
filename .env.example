# --- Required ---
# OpenAI covers embeddings (Stage 3), query transforms (Stage 4),
# and answer synthesis (Stage 6).
OPENAI_API_KEY=sk-...
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=knowledgeos-dev

# --- Optional ---
# Cohere Rerank v3; if unset, falls back to local cross-encoder (needs
# sentence-transformers) or retrieval-score ordering.
COHERE_API_KEY=

# Simple header auth for the API (X-API-Key). Leave empty to disable in dev.
API_AUTH_KEY=

# --- Tunables (TDD defaults) ---
MAX_CHUNK_TOKENS=512
OVERLAP_TOKENS=64
RETRIEVAL_ALPHA=0.7
TOP_K_CANDIDATES=20
TOP_K_FINAL=5
RRF_K=60
MIN_RERANK_SCORE=0.15
